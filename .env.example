# Optional market data provider.
# Default is Yahoo Finance fallback.
DATA_PROVIDER=yahoo

# Enable Finnhub daily candles for plain US tickers:
# DATA_PROVIDER=finnhub
# FINNHUB_API_KEY=put_your_key_here

# Enable Twelve Data multi-asset candles for stocks, forex, and crypto:
# DATA_PROVIDER=twelvedata
# TWELVE_DATA_API_KEY=put_your_key_here

# Enable Alpha Vantage daily time series for plain US tickers:
# DATA_PROVIDER=alphavantage
# ALPHA_VANTAGE_API_KEY=put_your_key_here

# Optional external sharia screening endpoint. If empty, THE-SFM uses local labels.
# SHARIA_API_URL=
# SHARIA_API_KEY=

# Optional local AI brain for voice commands.
# Install Ollama, then pull the model:
# ollama pull llama3.2:3b
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
